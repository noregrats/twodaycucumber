{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "types": ["node", "playwright"]
  },
  "include": ["src/**/*.ts", "features/**/*.ts"]
}